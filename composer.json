{
  "name": "rkw/oai-rkw",
  "description": "Integration von Shopware in cbisiere/oai-pmh Server",
  "repositories": [
    {
      "type": "path",
      "url": "packages/cbisiere/oai-pmh",
      "options": {
        "symlink": false
      }
    }
  ],
  "require": {
    "cbisiere/oai-pmh": "*",
    "monolog/monolog": "^3.9",
    "vlucas/phpdotenv": "^5.6",
    "guzzlehttp/guzzle": "^7.9"
  },
  "require-dev": {
    "symfony/var-dumper": "^7.3",
    "phpunit/phpunit": "^11.5"
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  },
  "autoload": {
    "psr-4": {
      "RKW\\OaiConnector\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "RKW\\OaiConnector\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true

}
